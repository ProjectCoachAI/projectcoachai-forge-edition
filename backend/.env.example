# ProjectCoachAI Backend — Environment Variables
# Copy this to .env and fill in your keys

# === Forge Lite: AI API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AI...

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === Email (SMTP) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM_NAME=ProjectCoachAI
SMTP_FROM_EMAIL=noreply@projectcoach.ai
REPLY_TO_EMAIL=support@projectcoach.ai

# === Server ===
PORT=3000
